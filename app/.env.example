# Copy to `.env` next to docker-compose.yml on the BBB and edit the values.

# --- registry ----------------------------------------------------------------
GHCR_USER=your-github-user
TAG=latest

# --- timezone ----------------------------------------------------------------
TZ=Europe/Paris

# --- serial / EnOcean --------------------------------------------------------
# Override only if you have moved the dongle. Default /dev/ttyO4 matches the
# legacy BBB wiring (UART4: P9.11 RX, P9.13 TX).
VDSENSOR_SERIAL_PORT=/dev/ttyO4

# --- MQTT (optional; omit / leave blank to disable HA bridge) ----------------
# VDSENSOR_MQTT_URL=mqtt://username:password@mosquitto.lan:1883
# VDSENSOR_MQTT_PREFIX=vdsensor
# VDSENSOR_HA_DISCOVERY_PREFIX=homeassistant
